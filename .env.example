# Copy this file to ".env" and fill in real values.
# .env stays at the project root — OUTSIDE the public/ web root — so it is
# never served over HTTP. Never commit the real .env.

# --- Database ---
# On Hostinger the host is usually "localhost". The DB name + user are the
# prefixed ones shown in hPanel > Databases (e.g. u123456_fourwheelszone).
DB_HOST=localhost
DB_PORT=3306
DB_NAME=fourwheelszone
DB_USER=root
DB_PASS=

# --- CORS ---
# Comma-separated list of frontend origins allowed to call this API.
# Add your real site here once deployed. Use "*" for quick testing only.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173
